# Copy to .env and fill in. .env is git-ignored.

# --- AWS ---
AWS_REGION=us-east-1
S3_BRONZE_BUCKET=my-life-in-data-bronze
S3_SILVER_BUCKET=my-life-in-data-silver

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your_account.us-east-1
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=TRANSFORMER
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=MY_LIFE
SNOWFLAKE_SCHEMA=RAW

# --- Spotify (https://developer.spotify.com/dashboard) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
SPOTIFY_REFRESH_TOKEN=

# --- GitHub (https://github.com/settings/tokens) ---
GITHUB_USERNAME=HarshikaReddyUppula
GITHUB_TOKEN=

# --- Google Calendar (https://console.cloud.google.com/apis/credentials) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
